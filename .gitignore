# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
.venv/
env/
venv/
ENV/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
*.egg
MANIFEST

# ── Rust ──────────────────────────────────────────────────────────────────────
target/
**/*.rs.bk
Cargo.lock

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Legacy / renamed artifacts (Atlas → ExVisit migration) ────────────────────
*.atlas
*.atlas.json
rename_script.ps1
rename_plan.md
atlas_pro/
scratch/model_debug.txt

# ── Benchmark runtime state (never commit) ────────────────────────────────────
# These contain timestamps, API key echoes in debug strings, and gigabytes
# of cloned repo trees. Always regenerated by `python scratch/run_vnext_openrouter.py`.
bench/.cache/
reports/tmp/

# ── Ephemeral generated files ─────────────────────────────────────────────────
# Auto-generated .exv sidecars and trajectory logs from benchmark runs.
# Checked-in .exv files (examples/) are intentional and excluded from this rule.
*.meta.json
*.traj.json
/scratch/model_debug.txt

# ── Secrets / credentials (hard block) ────────────────────────────────────────
.env
.env.*
*.pem
*.key
secrets.json

# ── Internal dev / session artifacts (never publish) ─────────────────────────
# These are local-only working notes and throwaway research scripts.
status.md
vision.md
scratch/
