*.atlas.json
rename_script.ps1
rename_plan.md
atlas_pro/
scratch/model_debug.txt

# ── Benchmark runtime state (never commit) ────────────────────────────────────
# Cloned repos, .exv files, workspaces, trajectories, result JSONs.
# Regenerated by run_nemotron_openhands.ps1 / run_vnext_openrouter.py
bench/.cache/
bench/venv_nemotron/
reports/tmp/

# ── Ephemeral generated files ─────────────────────────────────────────────────
# Auto-generated .exv sidecars and trajectory logs from benchmark runs.
# Checked-in .exv files (examples/) are intentional and excluded from this rule.
*.meta.json
*.traj.json
/scratch/model_debug.txt

# ── Secrets / credentials (hard block) ────────────────────────────────────────
.env
.env.*
*.pem
*.key
secrets.json

